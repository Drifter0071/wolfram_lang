{
  "name": "wolfram-lang",
  "displayName": "Wolfram Language",
  "description": "Wolfram language support for VS Code — syntax highlighting, intellisense, watch server, and Roblox project templates",
  "version": "0.2.0",
  "publisher": "wolfram",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/wolfram-lang"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "wolfram",
        "aliases": ["Wolfram"],
        "extensions": [".wrm"],
        "firstLine": "^-- .*Wolfram",
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "wolfram",
        "scopeName": "source.wrm",
        "path": "./src/syntaxes/wolfram.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "wolfram.setCompilerPath",
        "title": "Wolfram: Set Compiler Path"
      },
      {
        "command": "wolfram.showOutput",
        "title": "Wolfram: Show Output"
      },
      {
        "command": "wolfram.newProject",
        "title": "Wolfram: New Project"
      },
      {
        "command": "wolfram.startWatch",
        "title": "Wolfram: Start Watch Server"
      },
      {
        "command": "wolfram.stopWatch",
        "title": "Wolfram: Stop Watch Server"
      },
      {
        "command": "wolfram.compileFile",
        "title": "Wolfram: Compile Current File"
      }
    ],
    "keybindings": [
      {
        "command": "wolfram.compileFile",
        "key": "f5",
        "when": "editorLangId == wolfram"
      }
    ],
    "configuration": {
      "title": "Wolfram",
      "properties": {
        "wolfram.compilerPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the wolfram compiler executable (e.g., C:\\Users\\<name>\\.cargo\\bin\\wolfram.exe)"
        },
        "wolfram.watchOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the watch server when opening a .wrm file"
        },
        "wolfram.outputDir": {
          "type": "string",
          "default": "out",
          "description": "Output directory for compiled .luau files"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  }
}
