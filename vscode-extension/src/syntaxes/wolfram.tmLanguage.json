{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Wolfram",
  "scopeName": "source.wrm",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#fstrings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#definition-keywords"
    },
    {
      "include": "#access-modifiers"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-dash.wrm",
      "begin": "--",
      "end": "$"
    },
    "strings": {
      "name": "string.quoted.double.wrm",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.wrm",
          "match": "\\\\."
        }
      ]
    },
    "fstrings": {
      "name": "string.quoted.double.interpolated.wrm",
      "begin": "f\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.wrm",
          "match": "\\\\."
        },
        {
          "include": "#interpolation"
        }
      ]
    },
    "interpolation": {
      "name": "meta.embedded.expression.wrm",
      "begin": "\\{",
      "end": "\\}",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.wrm",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.wrm",
          "match": "\\b(if|else)\\b"
        },
        {
          "name": "keyword.control.loop.wrm",
          "match": "\\b(while|for|in|break|continue)\\b"
        },
        {
          "name": "keyword.control.return.wrm",
          "match": "\\b(return)\\b"
        },
        {
          "name": "keyword.operator.word.wrm",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.other.import.wrm",
          "match": "\\b(import|as)\\b"
        },
        {
          "name": "keyword.other.local.wrm",
          "match": "\\b(local)\\b"
        }
      ]
    },
    "definition-keywords": {
      "patterns": [
        {
          "name": "keyword.other.function.wrm",
          "match": "\\b(function)\\b"
        },
        {
          "name": "keyword.other.class.wrm",
          "match": "\\b(class)\\b"
        },
        {
          "name": "keyword.other.struct.wrm",
          "match": "\\b(struct|enum)\\b"
        }
      ]
    },
    "access-modifiers": {
      "name": "storage.modifier.access.wrm",
      "match": "\\b(public|private)\\b"
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.wrm",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.wrm",
          "match": "\\b(nil)\\b"
        },
        {
          "name": "variable.language.self.wrm",
          "match": "\\b(self)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.compound.wrm",
          "match": "\\+=|-=|\\*=|/=|%="
        },
        {
          "name": "keyword.operator.comparison.wrm",
          "match": "==|~=|!=|<=|>="
        },
        {
          "name": "keyword.operator.assignment.wrm",
          "match": "="
        },
        {
          "name": "keyword.operator.concatenation.wrm",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.arithmetic.wrm",
          "match": "\\*\\*|//|\\+|\\-|\\*|/|%"
        },
        {
          "name": "keyword.operator.comparison.wrm",
          "match": "<|>"
        },
        {
          "name": "keyword.operator.ternary.wrm",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.separator.wrm",
          "match": ";|,"
        },
        {
          "name": "keyword.operator.access.wrm",
          "match": "\\.|:"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.wrm",
          "match": "(?<=function\\s+)[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "entity.name.type.class.wrm",
          "match": "(?<=class\\s+)[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "variable.other.wrm",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
